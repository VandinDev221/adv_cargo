# Local (Docker): docker compose up -d → postgres/postgres, banco advcargo
# Produção (Neon): use a connection string do console.neon.tech (inclua ?sslmode=require)
# Render: defina DATABASE_URL, JWT_SECRET, FRONTEND_URL (URL do front na Vercel); PORT é definido pelo Render
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/advcargo"
JWT_SECRET="sua-chave-secreta-jwt-aqui"
PORT=3001
NODE_ENV=development
UPLOAD_DIR=./uploads

# Produção: URL do frontend (Vercel) para CORS
FRONTEND_URL="https://localhost:5173"

# Opcional: rodar a API em HTTPS (certificado autoassinado ou válido)
# USE_HTTPS=true
# SSL_KEY_PATH=./certs/key.pem
# SSL_CERT_PATH=./certs/cert.pem

# Resend (verificação de e-mail no cadastro)
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=AdvCargo <noreply@recevedmails.online>

# Groq (leitor jurídico com IA)
# GROQ_API_KEY=gsk_xxxxxxxx
# GROQ_MODEL=llama-3.3-70b-versatile
