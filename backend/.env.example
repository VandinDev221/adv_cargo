# Local (Docker): docker compose up -d → postgres/postgres, banco advcargo
# Produção (Neon): use a connection string do console.neon.tech (inclua ?sslmode=require)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/advcargo"
JWT_SECRET="sua-chave-secreta-jwt-aqui"
PORT=3001
NODE_ENV=development
UPLOAD_DIR=./uploads

# Sempre usar HTTPS em produção
FRONTEND_URL="https://localhost:5173"

# Opcional: rodar a API em HTTPS (certificado autoassinado ou válido)
# USE_HTTPS=true
# SSL_KEY_PATH=./certs/key.pem
# SSL_CERT_PATH=./certs/cert.pem
