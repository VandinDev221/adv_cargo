# URL da API em produção (build time). Na Vercel: Settings → Environment Variables
# Exemplo deste projeto: https://advcargo-api.onrender.com (sem barra no final)
VITE_API_URL=

# Google OAuth — opcional se GOOGLE_CLIENT_ID estiver no backend (busca automática em /api/auth/config)
# Ou defina aqui para não depender da API no build:
VITE_GOOGLE_CLIENT_ID=